{
  "name": "proxymancer",
  "version": "0.2.0",
  "description": "Minimal Chrome (MV3) forward-proxy switcher — address + bypass list from the toolbar.",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && node scripts/pack.mjs",
    "clean": "rm -rf dist proxymancer.crx"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/chrome": "^0.2.2",
    "crx3": "^2.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
